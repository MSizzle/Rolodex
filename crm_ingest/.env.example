# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Transcription (OpenAI Whisper API) ─────────────────────────────────────────
# Required for audio transcription via OpenAI's Whisper API.
# To use local Whisper instead, set TRANSCRIPTION_PROVIDER=local
# and run: pip install openai-whisper
OPENAI_API_KEY=sk-...
TRANSCRIPTION_PROVIDER=openai   # options: openai | local

# ── Google Sheets ──────────────────────────────────────────────────────────────
# Option A: inline JSON string (recommended — no extra file needed)
# Run: cat credentials.json | tr -d '\n'  and paste the output below.
GOOGLE_CREDENTIALS_JSON=

# Option B: path to a local credentials JSON file (ignored by git)
# GOOGLE_CREDENTIALS_FILE=credentials.json

GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=

# ── Optional behaviour ─────────────────────────────────────────────────────────
# Minimum confidence score (0.0–1.0) to suggest an existing record match.
MATCH_CONFIDENCE_THRESHOLD=0.7

# Set to 1 to print raw Claude responses for debugging.
DEBUG_CLAUDE=0
